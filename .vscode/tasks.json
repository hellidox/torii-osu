{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Stop osu debug session",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$ErrorActionPreference='SilentlyContinue'; Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'dotnet.exe' -and $_.CommandLine -match 'torii-osu' -and $_.CommandLine -match 'osu-gu!\\.dll' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }; Get-Process 'osu-gu!' | Stop-Process -Force"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build osu! (Debug)",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "osu.Desktop",
                "-p:GenerateFullPaths=true",
                "-m",
                "-verbosity:m"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build osu! (Debug, Safe)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Stop osu debug session",
                "Build osu! (Debug)"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build osu! (Release)",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "osu.Desktop",
                "-p:Configuration=Release",
                "-p:GenerateFullPaths=true",
                "-m",
                "-verbosity:m"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build osu! (Release, Safe)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Stop osu debug session",
                "Build osu! (Release)"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build tests (Debug)",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "osu.Game.Tests",
                "-p:GenerateFullPaths=true",
                "-m",
                "-verbosity:m"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build tests (Release)",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "osu.Game.Tests",
                "-p:Configuration=Release",
                "-p:GenerateFullPaths=true",
                "-m",
                "-verbosity:m"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build tournament tests (Debug)",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "osu.Game.Tournament.Tests",
                "-p:GenerateFullPaths=true",
                "-m",
                "-verbosity:m"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build tournament tests (Release)",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "osu.Game.Tournament.Tests",
                "-p:Configuration=Release",
                "-p:GenerateFullPaths=true",
                "-m",
                "-verbosity:m"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build benchmarks",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "osu.Game.Benchmarks",
                "-p:Configuration=Release",
                "-p:GenerateFullPaths=true",
                "-m",
                "-verbosity:m"
            ],
            "group": "build",
            "problemMatcher": "$msCompile"
        }
    ]
}
